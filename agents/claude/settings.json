{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(./manage.py:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(direnv:*)",
      "Bash(django-admin:*)",
      "Bash(docker:*)",
      "Bash(done)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(npm run type-check:*)",
      "Bash(npx tsc:*)",
      "Bash(npx:*)",
      "Bash(npm run routes:generate:*)",
      "Bash(npx @tanstack/router-cli generate)",
      "Bash(python -c:*)",
      "Bash(python -m py_compile:*)",
      "Bash(python manage.py:*)",
      "Bash(python3:*)",
      "Bash(uv:*)",
      "Bash(wc:*)",
      "Skill(superpowers:brainstorming)",
      "Skill(superpowers:executing-plans)",
      "Skill(superpowers:requesting-code-review)",
      "Skill(superpowers:systematic-debugging)",
      "WebSearch",
      "WebFetch(domain:headlessui.com)",
      "WebFetch(domain:www.figma.com)",
      "mcp__pencil"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"${HOME}/.bun/bin/bun\" \"$(ls -td ${HOME}/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)src/index.ts\"'"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "context7@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "clangd-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "better-icons": {
      "command": "npx",
      "args": [
        "-y",
        "better-icons"
      ]
    }
  },
  "verbose": true
}
